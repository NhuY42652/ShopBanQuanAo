@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager
<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="utf-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge">
	<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
	<meta name="description" content="Responsive Admin &amp; Dashboard Template based on Bootstrap 5">
	<meta name="author" content="AdminKit">
	<meta name="keywords" content="adminkit, bootstrap, bootstrap 5, admin, dashboard, template, responsive, css, sass, html, theme, front-end, ui kit, web">

	<link rel="preconnect" href="https://fonts.gstatic.com">
	<link rel="shortcut icon" href="img/icons/icon-48x48.png" />
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

	<link rel="canonical" href="https://demo-basic.adminkit.io/pages-blank.html" />

	<title>Trang quản trị - SHOP QUẦN ÁO MIKA</title>

	<link href="~/css/app.css" rel="stylesheet">
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
</head>
<style>
	.navbar-bg {
		background-color: #e3f2fd !important;
	}

	.footer {
		background-color: #e3f2fd !important; 
		border-top: 1px solid #bbdefb;
	}

	.main-content-bg {
		

		background-image: url('/images/carousel/bg3.jpg');
		background-size: cover; 
		background-attachment: fixed; 
		background-position: center;
		padding-top: 50px;
		padding-bottom: 50px;
	}
	
	.sidebar {
		background-color: #2c3e50 !important; 
	}

	.sidebar-link, .sidebar-header, .sidebar-brand {
		color: #ecf0f1 !important; 
	}

	.sidebar-item.active .sidebar-link {
		background-color: #34495e !important; 
		color: #ffffff !important;
	}

	.sidebar-link:hover {
		background-color: #3e566d !important;
		color: #ffffff !important;
	}

	.sidebar-header.text-info {
		color: #79a6d0 !important;
	}
	
</style>

<body>
	<div class="wrapper">
		<nav id="sidebar" class="sidebar js-sidebar ">
			<div class="sidebar-content js-simplebar">
				<a class="sidebar-brand" asp-controller="Home" asp-action="Index">
					<span class="align-middle">SHOP QUẦN ÁO MIKA</span>
				</a>
				@if (SignInManager.IsSignedIn(User))
				{
					<ul class="sidebar-nav">
						<li class="sidebar-header text-info">
							HỆ THỐNG
						</li>

						<li class="sidebar-item active">
							<a class="sidebar-link" href="">
								<i class="align-middle" data-feather="settings"></i> <span class="align-middle">Bảng Điều Khiển</span>
							</a>
						</li>

						<li class="sidebar-item">
							<a class="sidebar-link" asp-controller="Khachhangs" asp-action="Index">
								<i class="align-middle" data-feather="users"></i> <span class="align-middle">Quản Lý Khách Hàng</span>
							</a>
						</li>
						<li class="sidebar-item">
							<a class="sidebar-link" asp-controller="Customers" asp-action="DoanhThu">
								<i class="align-middle" data-feather="file-text"></i> <span class="align-middle">Báo Cáo Doanh Thu</span>
							</a>
						</li>
						<li class="sidebar-header text-info">
							DANH MỤC
						</li>

						<li class="sidebar-item">
							<a class="sidebar-link" asp-controller="Danhmucs" asp-action="Index">
								<i class="align-middle" data-feather="layers"></i> <span class="align-middle">Quản Lý Danh Mục</span>
							</a>
						</li>

						<li class="sidebar-item">
							<a class="sidebar-link" asp-controller="Mathangs" asp-action="Index">
								<i class="align-middle" data-feather="box"></i> <span class="align-middle">Quản lý Sản Phẩm</span>
							</a>
						</li>
						<li class="sidebar-item">
							<a class="sidebar-link" asp-controller="ProductVariants" asp-action="Index">
								<i class="align-middle" data-feather="layers"></i> <span class="align-middle">Quản lý Biến Thể</span>
							</a>
						</li>
						<li class="sidebar-header text-info">
							KINH DOANH
						</li>
						<li class="sidebar-item">
							<a class="sidebar-link" asp-controller="Hoadons" asp-action="Index">
								<i class="align-middle" data-feather="shopping-cart"></i> <span class="align-middle">Quản Lý Đơn Hàng</span>
							</a>
						</li>

						<li class="sidebar-item">
							<a class="sidebar-link" asp-controller="Cthoadons" asp-action="Index">
								<i class="align-middle" data-feather="file-text"></i> <span class="align-middle">Quản Lý Chi Tiết Hóa Đơn</span>
							</a>
						</li>
						<li class="sidebar-item">
							<a class="sidebar-link" asp-controller="KhuyenMais" asp-action="Index">
								<i class="align-middle" data-feather="gift"></i> <span class="align-middle">Chương Trình Khuyến Mãi</span>
							</a>
						</li>
						<li class="sidebar-item">
							<a class="sidebar-link" asp-controller="SuKiens" asp-action="Index">
								<i class="align-middle" data-feather="gift"></i> <span class="align-middle">Chương Trình Sự Kiện</span>
							</a>
						</li>
					</ul>
				}
			</div>
		</nav>

		<div class="main">
			<nav class="navbar navbar-expand navbar-light navbar-bg">
				<a class="sidebar-toggle js-sidebar-toggle">
					<i class="hamburger align-self-center"></i>
				</a>
				@if (SignInManager.IsSignedIn(User))
				{
					<div class="navbar-collapse collapse">
						<ul class="navbar-nav navbar-align">

							<li class="nav-item dropdown">
								<a class="nav-icon dropdown-toggle d-inline-block d-sm-none" href="#" data-bs-toggle="dropdown">
									<i class="align-middle" data-feather="settings"></i>
								</a>

								<a class="nav-link dropdown-toggle d-none d-sm-inline-block" href="#" data-bs-toggle="dropdown">
									<span class="text-dark text-bg-info">Hello @User.Identity?.Name</span>
								</a>
								<div class="dropdown-menu dropdown-menu-end">
									<a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage"><i class="align-middle me-1" data-feather="user"></i> Hồ Sơ</a>
									<a class="dropdown-item" href="#"><i class="align-middle me-1" data-feather="pie-chart"></i> Analytics</a>
									<div class="dropdown-divider"></div>
									<a class="dropdown-item" href="index.html"><i class="align-middle me-1" data-feather="settings"></i> Settings & Privacy</a>
									<a class="dropdown-item" href="#"><i class="align-middle me-1" data-feather="help-circle"></i> Help Center</a>
									<div class="dropdown-divider"></div>
									<span class="dropdown-item">
										<form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
											<button type="submit" class="nav-link btn btn-link text-dark">Đăng Xuất</button>
										</form>
									</span>
								</div>
							</li>
						</ul>
					</div>
				}
				else
				{
					<ul class="navbar-nav navbar-align">					
						<li class="nav-item">
							<a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">Đăng Nhập</a>
						</li>
					</ul>
				}
			</nav>

			<main class="content">
				<div class="main-content-bg">
					<h1 class="h3 mb-3 text-center fw-bold text-warning">Chào Mừng Đến Với Trang Quản Trị</h1>
					<h1 class="h3 mb-3 text-center fw-bold text-warning">Vui Lòng Chọn Chức Năng </h1>

					<div class="row">
						<div class="col-12">
							@RenderBody()
						</div>
					</div>

				</div>
			</main>

			<footer class="footer">
				<div class="container-fluid">
					<div class="row text-muted">
						<div class="col-6 text-start">
							<p class="mb-0 mx-auto">
								<a class="text-muted text-center" href=""><strong>SHOP QUẦN ÁO MIKA</strong></a>
							</p>
						</div>
						<div class="col-6 text-end">
							<ul class="list-inline">
								<li class="list-inline-item">
									<a class="text-muted" href="">Hỗ trợ</a>
								</li>
							</ul>
						</div>
					</div>
				</div>
			</footer>
		</div>
	</div>
	<script>
		feather.replace();
	</script>
	<script src="~/js/app.js"></script>
	@await RenderSectionAsync("Scripts", required: false)
</body>

</html>