@model ShopBanQuanAoOnline.Models.Mathang

@{
    ViewData["Title"] = "Details";
}

<h1>Chi tiết</h1>

<div>
    <h4>Mathang</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Ten)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Ten)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.GiaGoc)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.GiaGoc)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.GiaBan)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.GiaBan)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.SoLuong)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.SoLuong)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.MoTa)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.MoTa)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.LuotXem)
        </dt>
        <dd class="col-sm-10">
            @(Model.LuotXem ?? 0)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.LuotMua)
        </dt>
        <dd class="col-sm-10">
            @(Model.LuotMua ?? 0)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.HinhAnh)
        </dt>
        <dd class="col-sm-10">
            <img width="150" height="150" src="~/images/@Html.DisplayFor(model => model.HinhAnh)" />
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.MaDmNavigation)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.MaDmNavigation.Ten)
        </dd>

        <dt class="col-sm-2">
            Biến thể
        </dt>
        <dd class="col-sm-10">
            @if (Model.ProductVariants != null && Model.ProductVariants.Any())
            {
                <ul class="mb-0">
                    @foreach (var v in Model.ProductVariants)
                    {
                        <li>@v.Size - @v.Color (Kho: @v.Stock, SKU: @v.Sku)</li>
                    }
                </ul>
            }
            else
            {
                <span class="text-muted">Chưa có biến thể.</span>
            }
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.MaMh">Edit</a> |
    <a asp-controller="ProductVariants" asp-action="Index" asp-route-maMh="@Model?.MaMh">Quản lý biến thể</a> |
    <a asp-action="Index">Back to List</a>
</div>