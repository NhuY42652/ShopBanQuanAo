@model IEnumerable<ShopBanQuanAoOnline.Models.Mathang>

@{
    ViewData["Title"] = "Index";
    System.Globalization.CultureInfo culture = new System.Globalization.CultureInfo("vi-VN");
}

<h1>Quản Lý Sản Phẩm</h1>

<p class="mb-3">
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus-circle"></i> Thêm Mặt hàng mới
    </a>
</p>

<div class="table-responsive">
    <table class="table table-bordered table-striped table-hover table-sm text-center">
        <thead class="table-success text-center">
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.HinhAnh)
                </th>
                <th style="white-space: nowrap;">
                    @Html.DisplayNameFor(model => model.Ten)
                </th>
                <th style="white-space: nowrap;">
                    @Html.DisplayNameFor(model => model.MaDmNavigation)
                </th>
                <th style="white-space: nowrap;">
                    @Html.DisplayNameFor(model => model.GiaBan)
                </th>
                <th style="white-space: nowrap;">
                    @Html.DisplayNameFor(model => model.SoLuong)
                </th>
                <th>
                    Lượt xem/mua
                </th>
                <th style="white-space: nowrap;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="align-middle">
                        <img width="80" height="80" src="~/images/@Html.DisplayFor(modelItem => item.HinhAnh)" class="img-thumbnail" alt="@item.Ten" />
                    </td>
                    <td class="text-start align-middle">
                        <strong>@Html.DisplayFor(modelItem => item.Ten)</strong>
                        <br />
                        <small class="text-muted">Mã: @item.MaMh</small>
                    </td>
                    <td class="align-middle">
                        @Html.DisplayFor(modelItem => item.MaDmNavigation.Ten)
                    </td>
                    <td class="align-middle">
                        <strong class="text-danger">@string.Format(culture, "{0:N0}", item.GiaBan) VNĐ</strong>
                        @if (item.GiaGoc > item.GiaBan)
                        {
                            <br />
                            <del class="text-muted small">@string.Format(culture, "{0:N0}", item.GiaGoc) VNĐ</del>
                        }
                    </td>
                    <td class="align-middle font-weight-bold">
                        @(item.SoLuong ?? 0)
                    </td>
                    <td class="align-middle small">
                        Xem: @(item.LuotXem ?? 0)<br />
                        Mua: @(item.LuotMua ?? 0)
                    </td>
                    <td class="align-middle" style="min-width: 150px;">
                        <a asp-action="Edit" asp-route-id="@item.MaMh" class="btn btn-sm btn-success mb-1" title="Chỉnh sửa">
                            <i class="fas fa-edit"></i> Sửa
                        </a>
                        <a asp-action="Details" asp-route-id="@item.MaMh" class="btn btn-sm btn-info mb-1" title="Chi tiết">
                            <i class="fas fa-info-circle"></i> Chi tiết
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.MaMh" class="btn btn-sm btn-danger" title="Xóa">
                            <i class="fas fa-trash-alt"></i> Xóa
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>