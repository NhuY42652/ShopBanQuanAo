@model IEnumerable<ShopBanQuanAoOnline.Models.Hoadon>

@{
    ViewData["Title"] = "Quản lý Đơn Hàng";
}

<h1>Quản lý Đơn Hàng</h1>
<p>
    <a asp-action="Create">Thêm mới</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Mã HĐ</th>
            <th>Ngày lập</th>
            <th>Tổng tiền</th>
            <th>Trạng thái</th>
            <th>Khách hàng (Mã KH)</th>
            <th>Tên Khách hàng</th>
            <th>Hành động</th> 
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>               
                <td>@item.MaHd</td>               
                <td>@item.Ngay</td>               
                <td>@item.TongTien?.ToString("N0") VNĐ</td>
                <td>
                    @switch (item.TrangThai)
                    {
                        case 0:
                            <span class="badge bg-warning text-dark">Chờ xử lý</span>
                            break;
                        case 1:
                            <span class="badge bg-info">Đang giao hàng</span>
                            break;
                        case 2:
                            <span class="badge bg-primary">Đã giao hàng (Chờ KH)</span>
                            break;
                        case 3:
                            <span class="badge bg-success">Hoàn thành</span>
                            break;
                        default:
                            <span class="badge bg-secondary text-bg-danger">Đã Hủy</span>
                            break;
                    }
                </td>

                <td>@item.MaKh</td>
                <td>@item.MaKhNavigation?.Ten</td> 
                <td>
                    @switch (item.TrangThai)
                    {
                        case 0:
                            <form asp-action="CapNhatTrangThai" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@item.MaHd" />
                                <input type="hidden" name="trangThaiMoi" value="1" />
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-success mb-1">Duyệt Đơn</button>
                            </form>
                            break;
                        case 1:
                            <form asp-action="CapNhatTrangThai" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@item.MaHd" />
                                <input type="hidden" name="trangThaiMoi" value="2" />
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-info mb-1">Đã giao hàng</button>
                            </form>
                            break;
                    }
                    <div class="mt-1">
                        <a asp-action="Details" asp-route-id="@item.MaHd" class="btn btn-sm btn-primary">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.MaHd" class="btn btn-sm btn-danger">Delete</a>
                    </div>

                </td>
            </tr>
        }
    </tbody>
</table>