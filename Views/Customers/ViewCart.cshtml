@model List<ShopBanQuanAoOnline.Models.CartItem>
<div class="customer-page-card p-4 p-lg-5 mt-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
        <h3 class="section-title mb-0">Giỏ hàng của bạn</h3>
        <span class="badge me-2" style="background-color:#d6f4ff; color:#0b6b86; border:1px solid #9fdef3;">
            @Model.Count sản phẩm
        </span>
    </div>

    @if (Model.Count > 0)
    {
        int stt = 1;
        int thanhtien = 0;
        int tongtien = 0;

        <div class="table-responsive border rounded-4">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-info">
                    <tr>
                        <th>STT</th>
                        <th>Sản phẩm</th>
                        <th>Biến thể</th>
                        <th>Giá</th>
                        <th style="min-width: 180px;">Số lượng</th>
                        <th>Thành tiền</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var i in Model)
                    {
                        thanhtien = (i.MatHang.GiaBan ?? 0) * i.SoLuong;

                        tongtien += thanhtien;
                        <tr>
                            <td>@(stt++)</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <img src="~/images/@(i.MatHang.HinhAnh)" class="img-thumbnail" width="56" />
                                    <span class="fw-semibold">@(i.MatHang.Ten)</span>
                                </div>
                            </td>
                            <td>@(i.VariantLabel ?? "Mặc định")</td>
                            <td>@(i.MatHang.GiaBan?.ToString("N0")) đ</td>
                            <td>
                                <form asp-action="UpdateItem" method="post" class="d-flex gap-2">
                                    <input name="id" type="hidden" value="@i.MatHang.MaMh" />
                                    <input name="variantId" type="hidden" value="@i.ProductVariantId" />
                                    <input name="quantity" type="number" asp-for="@(i.SoLuong)" class="form-control" min="1" />
                                    <input class="btn btn-outline-info" type="submit" value="Cập nhật" />
                                </form>
                            </td>
                            <td class="fw-semibold">@(thanhtien.ToString("N0")) đ</td>
                            <td>
                                <a asp-action="RemoveItem" asp-route-id="@i.MatHang.MaMh" asp-route-variantId="@i.ProductVariantId" class="btn btn-sm btn-outline-danger">
                                    Xóa
                                </a>
                            </td>
                        </tr>
                    }
                    <tr class="table-light">
                        <td colspan="5" class="text-end fw-semibold">Tổng tiền</td>
                        <td colspan="2"><strong class="text-danger fs-5">@(tongtien.ToString("N0")) đ</strong></td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div class="text-end">
            <a class="btn btn-outline-secondary me-2" asp-controller="Customers" asp-action="Index">Tiếp tục mua sắm</a>
            <a class="btn btn-info text-white" asp-action="CheckOut">Thanh toán</a>
        </div>
    }
    else
    {
        <p class="alert alert-warning">Giỏ hàng đang rỗng, hãy chọn thêm sản phẩm để tiếp tục nhé.</p>
        <div class="text-center">
            <a class="btn btn-outline-secondary" asp-controller="Customers" asp-action="Index">Tiếp tục mua sắm</a>
        </div>
    }
</div>