@model ShopBanQuanAoOnline.Models.Mathang

@{
    ViewData["Title"] = "Details";
    var availableVariants = (Model.ProductVariants ?? new List<ShopBanQuanAoOnline.Models.ProductVariant>())
        .Where(v => v.Stock > 0)
        .ToList();
    var colors = availableVariants
        .Select(v => v.Color)
        .Where(c => !string.IsNullOrWhiteSpace(c))
        .Distinct()
        .OrderBy(c => c)
        .ToList();
    var sizes = availableVariants
        .Select(v => v.Size)
        .Where(s => !string.IsNullOrWhiteSpace(s))
        .Distinct()
        .OrderBy(s => s)
        .ToList();
    var variantData = availableVariants.Select(v => new { id = v.Id, color = v.Color, size = v.Size, stock = v.Stock });
}

<div class="customer-page-card p-4 p-lg-5 mt-4">
    <h1 class="section-title h3 mb-3">Chi tiết sản phẩm</h1>

    <style>
        .variant-option {
            min-width: 72px;
            border-radius: 6px;
        }

            .variant-option.active {
                border-color: #0dcaf0 !important;
                color: #087990 !important;
                background-color: rgba(13, 202, 240, 0.12);
            }
    </style>

    <div class="row g-4 pt-2">
        <div class="col-lg-5">
            <div class="bg-white border rounded-4 p-3 h-100 shadow-sm">
                <img class="img-fluid rounded-3 w-100" style="max-height:460px; object-fit:cover;" src="~/images/@Html.DisplayFor(model => model.HinhAnh)" alt="@Model.Ten" />
            </div>
        </div>
        <div class="col-lg-7">
            <div class="bg-white border rounded-4 p-4 h-100 shadow-sm">
                <h2 class="h4 fw-bold text-info mb-2">@Model.Ten</h2>
                <p class="mb-2 text-muted">@Model.MoTa</p>
                <div class="mb-3">
                    <span class="badge me-2" style="background-color:#d6f4ff; color:#0b6b86; border:1px solid #9fdef3;">Danh mục: @Model.MaDmNavigation?.Ten</span>                    
                    <span class="badge bg-light text-secondary border me-2">Lượt xem: @(Model.LuotXem ?? 0)</span>
                    <span class="badge bg-light text-secondary border">Lượt mua: @(Model.LuotMua ?? 0)</span>
                </div>
                <div class="mb-3">
                    <span class="text-danger fs-4 fw-bold">@((Model.GiaBan ?? 0).ToString("n0")) đ</span>
                </div>

                <div class="mb-3">
                    <strong>Tồn kho:</strong>
                    @if ((Model.SoLuong ?? 0) > 0)
                    {
                        <span class="text-success fw-semibold">@(Model.SoLuong ?? 0) sản phẩm</span>
                    }
                    else
                    {
                        <span class="text-danger fw-semibold">Hết hàng</span>
                    }
                </div>

                @if (availableVariants.Any())
                {
                    <form asp-controller="Customers" asp-action="AddToCart" method="get" class="row g-3" id="variantForm">
                        <input type="hidden" name="id" value="@Model.MaMh" />
                        <input type="hidden" id="variantIdInput" name="variantId" />

                        <div class="col-12">
                            <label class="form-label fw-bold">Màu sắc</label>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var color in colors)
                                {
                                    <button type="button" class="btn btn-outline-secondary variant-option color-option" data-color="@color">@color</button>
                                }
                            </div>
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-bold">Size</label>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var size in sizes)
                                {
                                    <button type="button" class="btn btn-outline-secondary variant-option size-option" data-size="@size">@size</button>
                                }
                            </div>
                        </div>

                        <div class="col-12 text-muted" id="variantStockText">Vui lòng chọn màu và size.</div>

                        <div class="col-12 d-flex gap-2">
                            <button type="submit" class="btn btn-info text-white">
                                <i class="fa fa-cart-plus"></i> Thêm vào giỏ hàng
                            </button>
                            <a asp-controller="Customers" asp-action="Index" class="btn btn-outline-secondary">Tiếp tục mua sắm</a>
                        </div>
                    </form>

                    <script>
                        (() => {
                            const variants = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(variantData));

                            let selectedColor = null;
                            let selectedSize = null;
                            const variantIdInput = document.getElementById("variantIdInput");
                            const stockText = document.getElementById("variantStockText");
                            const form = document.getElementById("variantForm");

                            const updateSelectedStyle = (selector, selectedKey, key) => {
                                document.querySelectorAll(selector).forEach(btn => {
                                    btn.classList.toggle("active", btn.dataset[key] === selectedKey);
                                });
                            };

                            const updateVariant = () => {
                                const matched = variants.find(v => v.color === selectedColor && v.size === selectedSize);
                                if (matched) {
                                    variantIdInput.value = matched.id;
                                    stockText.textContent = `Còn ${matched.stock} sản phẩm có sẵn.`;
                                } else {
                                    variantIdInput.value = "";
                                    stockText.textContent = "Vui lòng chọn đúng tổ hợp màu/size còn hàng.";
                                }
                            };

                            document.querySelectorAll(".color-option").forEach(btn => {
                                btn.addEventListener("click", () => {
                                    selectedColor = btn.dataset.color;
                                    updateSelectedStyle(".color-option", selectedColor, "color");
                                    updateVariant();
                                });
                            });

                            document.querySelectorAll(".size-option").forEach(btn => {
                                btn.addEventListener("click", () => {
                                    selectedSize = btn.dataset.size;
                                    updateSelectedStyle(".size-option", selectedSize, "size");
                                    updateVariant();
                                });
                            });

                            form.addEventListener("submit", (e) => {
                                if (!variantIdInput.value) {
                                    e.preventDefault();
                                    alert("Vui lòng chọn màu và size hợp lệ trước khi thêm vào giỏ.");
                                }
                            });
                        })();
                    </script>
                }
                else
                {
                    <span class="text-danger lead">Hết hàng</span>
                }
            </div>
        </div>
    </div>
</div>