@model ShopBanQuanAoOnline.Models.Hoadon
@{
    ViewData["Title"] = "Đặt hàng thành công";
}
<div class="customer-page-card p-4 p-lg-5 mt-4">
    <h3 class="section-title">Đặt hàng thành công</h3>
    <p class="text-success fs-5 mb-0">Đơn hàng mã số <strong>@Model.MaHd</strong> trị giá <strong>@(Model.TongTien?.ToString("n0"))đ</strong> đã được hệ thống ghi nhận. Chúng tôi sẽ sớm liên hệ bạn để xác nhận.</p>

    @if (TempData["BankQrUrl"] != null)
    {
        <div class="card mt-3 border-info" style="max-width:460px;">
            <div class="card-header bg-info text-white fw-semibold">
                Thanh toán chuyển khoản bằng mã QR (đơn #@Model.MaHd)
            </div>
            <div class="card-body">
                <img src="@TempData["BankQrUrl"]" alt="Mã QR thanh toán" class="img-fluid border rounded mb-3" />
                
            </div>
            <div class="card-footer bg-light small text-muted">
                Vui lòng chuyển đúng số tiền và nội dung chuyển khoản để hệ thống đối soát nhanh hơn.
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info mt-3 mb-0">
            <strong>Phương thức thanh toán:</strong> COD - bạn thanh toán khi nhận hàng.
        </div>
    }
</div>