@model ShopBanQuanAoOnline.Models.Hoadon
@{
    ViewData["Title"] = "Đặt hàng thành công";
}
<h3 class="text-warmning">Đặt hàng thành công</h3>
<h3 class="text-success">
<p>Đơn hàng mã số @Model.MaHd trị giá @(Model.TongTien)đ đã được hệ thống ghi nhận. Chúng tôi sẽ sớm liên hệ bạn để xác nhận...</p>
</h3>
@if (TempData["ShippingMethodText"] != null)
{
    <p><strong>Phương thức vận chuyển:</strong> @TempData["ShippingMethodText"]</p>
}
@if (TempData["PaymentUrl"] != null)
{
    <p class="mt-3">
        <a class="btn btn-warning" href="@TempData["PaymentUrl"]" target="_blank">
            Thanh toán ngay với VNPay
        </a>
    </p>
}

@if (TempData["BankQrUrl"] != null)
{
    <div class="card mt-3" style="max-width:420px;">
        <div class="card-header bg-info text-white">
            Thanh toán chuyển khoản bằng mã QR
        </div>
        <div class="card-body">
            <img src="@TempData["BankQrUrl"]" alt="Mã QR thanh toán" class="img-fluid border rounded mb-3" />
            <p class="mb-1"><strong>Ngân hàng:</strong> @TempData["BankName"]</p>
            <p class="mb-1"><strong>Số tài khoản:</strong> @TempData["BankAccount"]</p>
            <p class="mb-1"><strong>Chủ tài khoản:</strong> @TempData["AccountName"]</p>
            <p class="mb-1"><strong>Số tiền:</strong> @Model.TongTien?.ToString("n0") đ</p>
            <p class="mb-0"><strong>Nội dung CK:</strong> @TempData["TransferContent"]</p>
        </div>
    </div>
}