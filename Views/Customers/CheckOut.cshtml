@model List<ShopBanQuanAoOnline.Models.CartItem>
@{
    ViewData["Title"] = "Thanh toán";    
    var defaultAddress = ViewBag.DefaultAddress as ShopBanQuanAoOnline.Models.Diachi;
}
<p>Vui lòng kiểm tra đầy đủ thông tin trước khi hoàn tất đơn hàng</p>
<div class="row">
    <div class="col">
        <h4 class="text-info">Thông tin giao hàng</h4>
        <form asp-action="CreateBill">
            <div class="mb-3">
                <label>Email</label>
                <input name="email" class="form-control" type="text" value="@ViewBag.khachhang.Email" readonly />
            </div>
            <div class="mb-3">
                <label>Họ tên</label>
                <input name="hoten" class="form-control" type="text" value="@ViewBag.khachhang.Ten" />
            </div>
            <div class="mb-3">
                <label>Điện thoại</label>
                <input name="dienthoai" class="form-control" type="text" value="@ViewBag.khachhang.DienThoai" />
            </div>

            <div class="mb-3">
                <label>Địa chỉ giao hàng</label>
                <textarea name="diachi" class="form-control" rows="3">@(defaultAddress?.DiaChi1)</textarea>
                <small class="form-text text-muted">Bạn có thể thay đổi địa chỉ giao hàng tại đây.</small>
            </div>

            <div class="mb-3 form-check">
                <input type="checkbox" class="form-check-input" id="saveAddress" name="saveAddress" value="true" checked>
                <label class="form-check-label" for="saveAddress">Lưu địa chỉ này làm địa chỉ mặc định</label>
            </div>

            <div class="mb-3">
                <label>Phương thức thanh toán</label>
                <select name="paymentMethod" class="form-select">
                    <option value="COD">Thanh toán khi nhận hàng (COD)</option>
                    <option value="BANK_QR">Chuyển khoản ngân hàng qua mã QR</option>
                    <option value="VNPAY">Thanh toán VNPay (Sandbox)</option>
                </select>
                <small class="form-text text-muted">
                    Gợi ý: chọn QR để chuyển khoản nhanh theo đúng số tiền đơn hàng.
                </small>
            </div>

            <div class="mb-3">
                <label>Phương thức vận chuyển</label>
                <select name="shippingMethod" class="form-select">
                    <option value="FAST">Nhanh (dự kiến 1-2 ngày)</option>
                    <option value="STANDARD">Tiêu chuẩn (dự kiến 2-4 ngày)</option>
                </select>
            </div>

            <div class="mb-3">
                <input type="submit" class="btn btn-primary" value="Xác nhận đơn hàng" />
            </div>
        </form>

    </div>
    <div class="col">
        <h4 class="text-info">Thông tin đơn hàng</h4>
        @if (Model.Count > 0)
        {
            int stt = 1;        
            int thanhtien = 0;     
            int tongtien = 0;      

            <table class="table">
                <tr class="table-info">
                    <th>STT</th>
                    <th>Sản phẩm</th>
                    <th>Giá</th>
                    <th>Biến thể</th>
                    <th>Số lượng</th>
                    <th>Thành tiền</th>

                </tr>
                @foreach (var i in Model)
                {
                    thanhtien = i.MatHang.GiaBan * i.SoLuong ?? 1;
                    tongtien += thanhtien;
                    <tr class="align-middle">
                        <td>@(stt++)</td>
                        <td>
                            <img src="~/images/@(i.MatHang.HinhAnh)" class="img-thumbnail" width="50" />
                            @(i.MatHang.Ten)
                        </td>
                        <td>@(i.MatHang.GiaBan?.ToString("n0")) đ</td>
                        <td>@(i.VariantLabel ?? "Mặc định")</td>
                        <td>@(i.SoLuong)</td>
                        <td>@(thanhtien.ToString("n0")) đ</td>

                    </tr>
                }
                <tr>
                    <td colspan="5" class="text-end fw-bold">Thành tiền</td>
                    <td><strong class="text-danger">@(tongtien.ToString("n0")) đ</strong></td>
                </tr>
            </table>

        }
    </div>
</div>